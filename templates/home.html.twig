{% extends 'base.html.twig' %}

{% block title %}Home - Hotel Diongco{% endblock %}

{% block body %}

{# ─── 1. HERO SECTION ─────────────────────────────────────────────────────── #}
<section class="relative h-[650px] overflow-hidden">
  <div id="hero-carousel" class="absolute inset-0 w-full h-full">
    <div class="carousel-slide absolute inset-0 bg-cover bg-center transition-opacity duration-1000"
         style="background-image: linear-gradient(rgba(0,20,77,0.6), rgba(0,1,34,0.6)), url('{{ asset('images/hotelpatterned.png') }}');"></div>
    <div class="carousel-slide absolute inset-0 bg-cover bg-center transition-opacity duration-1000"
         style="background-image: linear-gradient(rgba(0,20,77,0.6), rgba(0,1,34,0.6)), url('{{ asset('images/hotelroom.png') }}');"></div>
    <div class="carousel-slide absolute inset-0 bg-cover bg-center transition-opacity duration-1000"
         style="background-image: linear-gradient(rgba(0,20,77,0.6), rgba(0,1,34,0.6)), url('{{ asset('images/diningroom.png') }}');"></div>
    <div class="carousel-slide absolute inset-0 bg-cover bg-center transition-opacity duration-1000"
         style="background-image: linear-gradient(rgba(0,20,77,0.6), rgba(0,1,34,0.6)), url('{{ asset('images/hotelspa.png') }}');"></div>
  </div>

  {# Carousel Dots #}
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-20 flex gap-2">
    <span class="carousel-dot w-2.5 h-2.5 rounded-full bg-white opacity-80 cursor-pointer"></span>
    <span class="carousel-dot w-2.5 h-2.5 rounded-full bg-white opacity-40 cursor-pointer"></span>
    <span class="carousel-dot w-2.5 h-2.5 rounded-full bg-white opacity-40 cursor-pointer"></span>
    <span class="carousel-dot w-2.5 h-2.5 rounded-full bg-white opacity-40 cursor-pointer"></span>
  </div>

  <div class="relative z-10 flex flex-col items-center justify-center h-full text-center px-6">
    <p class="helvetica-condensed text-[rgb(242,182,34)] uppercase tracking-widest text-sm mb-3 opacity-0 translate-y-6 transition-all duration-700" id="hero-tag">
      Dumaguete City's Premier Hotel
    </p>
    <h1 id="hero-title" style="font-family:'Cinzel', serif;"
        class="font-thin text-5xl md:text-6xl text-white mb-4 opacity-0 translate-y-6 transition-all duration-1000">
      Experience Luxury & Comfort
    </h1>
    <p id="hero-subtitle" class="helvetica-condensed text-lg md:text-2xl text-white mt-2 opacity-0 translate-y-6 transition-all duration-1000 max-w-xl">
      Where every stay becomes an unforgettable memory.
    </p>
    <div class="mt-8 flex flex-col sm:flex-row gap-4 opacity-0 translate-y-6 transition-all duration-1000" id="hero-buttons">
      <a href="{{ path('app_login') }}"
         class="bg-[rgb(29,53,153)] hover:bg-[rgb(242,182,34)] transition-colors text-white px-8 py-3 rounded-lg font-semibold">
        Book Now
      </a>
      <a href="#about"
         class="border border-white text-white hover:bg-white hover:text-[rgb(29,53,153)] transition-colors px-8 py-3 rounded-lg font-semibold">
        Learn More
      </a>
    </div>
  </div>
</section>

{# ─── 2. ABOUT SECTION ────────────────────────────────────────────────────── #}
<section id="about" class="py-20 bg-white">
  <div class="container mx-auto px-6 flex flex-col md:flex-row items-start gap-12">

    {# TEXT (LEFT) #}
    <div class="md:w-1/2 flex flex-col">

      <p class="helvetica-condensed text-[rgb(242,182,34)] uppercase tracking-widest text-sm mb-3">
        About Us
      </p>

      <h2 style="font-family:'Cinzel', serif;"
          class="font-thin text-3xl md:text-4xl mb-5 text-gray-900 leading-snug">
        The perfect balance of luxury and warmth.
      </h2>

      <p style="letter-spacing: 0.03em"
         class="helvetica-condensed text-base text-[rgb(67,85,145)] leading-relaxed mb-6 max-w-lg">
        At Hotel Diongco, every detail is crafted for your comfort. From elegant accommodations to world-class amenities,
        we offer exceptional service for business, leisure, or special occasions — right in the heart of Dumaguete City.
      </p>

      {# HORIZONTAL STATS #}
      <div class="flex flex-wrap sm:flex-nowrap gap-4">
        <div class="flex-1 text-center p-4 bg-gray-50 rounded-lg">
          <p style="font-family:'Cinzel', serif;" class="text-2xl font-thin text-[rgb(29,53,153)]">15+</p>
          <p class="helvetica-condensed text-xs text-[rgb(67,85,145)] mt-1">Years of Service</p>
        </div>

        <div class="flex-1 text-center p-4 bg-gray-50 rounded-lg">
          <p style="font-family:'Cinzel', serif;" class="text-2xl font-thin text-[rgb(29,53,153)]">50+</p>
          <p class="helvetica-condensed text-xs text-[rgb(67,85,145)] mt-1">Luxury Rooms</p>
        </div>

        <div class="flex-1 text-center p-4 bg-gray-50 rounded-lg">
          <p style="font-family:'Cinzel', serif;" class="text-2xl font-thin text-[rgb(29,53,153)]">5★</p>
          <p class="helvetica-condensed text-xs text-[rgb(67,85,145)] mt-1">Guest Rating</p>
        </div>

        <div class="flex-1 text-center p-4 bg-gray-50 rounded-lg">
          <p style="font-family:'Cinzel', serif;" class="text-2xl font-thin text-[rgb(29,53,153)]">24/7</p>
          <p class="helvetica-condensed text-xs text-[rgb(67,85,145)] mt-1">Concierge</p>
        </div>
      </div>

      {# BUTTON WITH MARGIN-TOP #}
      <div class="mt-6">
        <a href="{{ path('about') }}"
           class="inline-block bg-[rgb(29,53,153)] hover:bg-[rgb(242,182,34)] text-white px-6 py-2 rounded-lg text-sm">
          Discover Our Story
        </a>
      </div>

    </div>

    {# IMAGE (RIGHT) #}
    <div class="md:w-1/2 flex justify-center md:justify-end">
      <img src="{{ asset('images/hotel.png') }}"
           alt="Hotel Diongco"
           class="w-full max-w-md h-[300px] object-cover rounded-xl shadow-lg">
    </div>

  </div>
</section>



{# ─── 3. ROOMS SECTION ────────────────────────────────────────────────────── #}
<section id="rooms" class="py-20 bg-gray-50">
  <div class="container mx-auto px-6">
    <div class="text-center mb-12">
      <p class="helvetica-condensed text-[rgb(242,182,34)] uppercase tracking-widest text-sm mb-2">Accommodations</p>
      <h2 class="text-3xl md:text-4xl font-thin" style="font-family:'Cinzel', serif;">Our Rooms</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

      <div class="bg-white rounded-xl shadow-md overflow-hidden group hover:shadow-xl transition-shadow">
        <div class="relative overflow-hidden h-52">
          <img src="{{ asset('images/deluxe.png') }}" alt="Deluxe Room"
               class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
          <div class="absolute inset-0 bg-[rgb(0,20,77)] opacity-0 group-hover:opacity-20 transition-opacity"></div>
        </div>
        <div class="p-6">
          <h3 class="helvetica-condensed text-xl font-semibold text-gray-800">Deluxe Room</h3>
          <p class="helvetica-condensed text-[rgb(67,85,145)] text-sm mt-2 leading-relaxed">
            Spacious and comfortable with modern amenities, perfect for a relaxing retreat.
          </p>
          <a href="{{ path('app_login') }}"
             class="inline-block mt-4 text-sm text-[rgb(29,53,153)] hover:text-[rgb(242,182,34)] font-semibold transition-colors">
            View Room →
          </a>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-md overflow-hidden group hover:shadow-xl transition-shadow">
        <div class="relative overflow-hidden h-52">
          <img src="{{ asset('images/suite.png') }}" alt="Suite Room"
               class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
          <div class="absolute inset-0 bg-[rgb(0,20,77)] opacity-0 group-hover:opacity-20 transition-opacity"></div>
        </div>
        <div class="p-6">
          <h3 class="helvetica-condensed text-xl font-semibold text-gray-800">Suite Room</h3>
          <p class="helvetica-condensed text-[rgb(67,85,145)] text-sm mt-2 leading-relaxed">
            Luxury suite with a private balcony and stunning city views for ultimate comfort.
          </p>
          <a href="{{ path('app_login') }}"
             class="inline-block mt-4 text-sm text-[rgb(29,53,153)] hover:text-[rgb(242,182,34)] font-semibold transition-colors">
            View Room →
          </a>
        </div>
      </div>

      <div class="bg-white rounded-xl shadow-md overflow-hidden group hover:shadow-xl transition-shadow">
        <div class="relative overflow-hidden h-52">
          <img src="{{ asset('images/hotelroom.png') }}" alt="Standard Room"
               class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
          <div class="absolute inset-0 bg-[rgb(0,20,77)] opacity-0 group-hover:opacity-20 transition-opacity"></div>
        </div>
        <div class="p-6">
          <h3 class="helvetica-condensed text-xl font-semibold text-gray-800">Standard Room</h3>
          <p class="helvetica-condensed text-[rgb(67,85,145)] text-sm mt-2 leading-relaxed">
            Cozy and affordable with essential amenities, ideal for short stays.
          </p>
          <a href="{{ path('app_login') }}"
             class="inline-block mt-4 text-sm text-[rgb(29,53,153)] hover:text-[rgb(242,182,34)] font-semibold transition-colors">
            View Room →
          </a>
        </div>
      </div>

    </div>
  </div>
</section>

{# ─── 4. AMENITIES SECTION ────────────────────────────────────────────────── #}
<section id="amenities" class="py-20 bg-white">
  <div class="container mx-auto px-6">
    <div class="text-center mb-12">
      <p class="helvetica-condensed text-[rgb(242,182,34)] uppercase tracking-widest text-sm mb-2">What We Offer</p>
      <h2 class="text-3xl md:text-4xl font-thin" style="font-family:'Cinzel', serif;">Amenities & Services</h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">

      <div class="bg-gray-50 rounded-xl overflow-hidden group hover:shadow-lg transition-shadow">
        <div class="overflow-hidden h-44">
          <img src="{{ asset('images/hotelspa.png') }}" alt="Luxury Spa"
               class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
        </div>
        <div class="p-5">
          <h3 class="helvetica-condensed text-lg font-semibold text-gray-800">Spa</h3>
          <p class="helvetica-condensed text-[rgb(67,85,145)] text-sm mt-1">
            Relax and rejuvenate with our luxury spa treatments.
          </p>
        </div>
      </div>

      <div class="bg-gray-50 rounded-xl overflow-hidden group hover:shadow-lg transition-shadow">
        <div class="overflow-hidden h-44">
          <img src="{{ asset('images/bar.png') }}" alt="Lounge Bar"
               class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
        </div>
        <div class="p-5">
          <h3 class="helvetica-condensed text-lg font-semibold text-gray-800">Bar</h3>
          <p class="helvetica-condensed text-[rgb(67,85,145)] text-sm mt-1">
            Unwind with cocktails and music at our stylish lounge bar.
          </p>
        </div>
      </div>

      <div class="bg-gray-50 rounded-xl overflow-hidden group hover:shadow-lg transition-shadow">
        <div class="overflow-hidden h-44">
          <img src="{{ asset('images/gym.png') }}" alt="Modern Gym"
               class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
        </div>
        <div class="p-5">
          <h3 class="helvetica-condensed text-lg font-semibold text-gray-800">Gym</h3>
          <p class="helvetica-condensed text-[rgb(67,85,145)] text-sm mt-1">
            Stay fit with modern equipment and spacious workout areas.
          </p>
        </div>
      </div>

      <div class="bg-gray-50 rounded-xl overflow-hidden group hover:shadow-lg transition-shadow">
        <div class="overflow-hidden h-44">
          <img src="{{ asset('images/pool.png') }}" alt="Infinity Pool"
               class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500">
        </div>
        <div class="p-5">
          <h3 class="helvetica-condensed text-lg font-semibold text-gray-800">Pool</h3>
          <p class="helvetica-condensed text-[rgb(67,85,145)] text-sm mt-1">
            Take a refreshing swim in our outdoor infinity pool.
          </p>
        </div>
      </div>

    </div>
  </div>
</section>

{# ─── 5. REWARDS SECTION ──────────────────────────────────────────────────── #}
<section id="rewards" class="py-20 bg-gray-50">
  <div class="container mx-auto px-6 flex flex-col md:flex-row items-center gap-12">
    <div class="flex justify-center md:w-1/2">
      <img src="{{ asset('images/hotelrewards.png') }}" alt="Hotel Rewards"
           class="rounded-2xl shadow-xl w-full md:w-4/5">
    </div>
    <div class="md:w-1/2">
      <p class="helvetica-condensed text-[rgb(242,182,34)] uppercase tracking-widest text-sm mb-3">Loyalty Program</p>
      <h2 style="font-family:'Cinzel', serif;" class="text-3xl md:text-4xl font-thin mb-5 text-gray-900">
        Join Our Rewards Program
      </h2>
      <p class="helvetica-condensed text-base text-[rgb(67,85,145)] leading-relaxed mb-6">
        Earn points every time you book a room or enjoy our amenities.
        Accumulate and redeem them for exclusive discounts and special offers.
        Your loyalty deserves to be rewarded!
      </p>
      <ul class="space-y-3 text-[rgb(67,85,145)] helvetica-condensed mb-8">
        <li class="flex items-center gap-2">
          <span class="w-5 h-5 rounded-full bg-[rgb(29,53,153)] text-white text-xs flex items-center justify-center flex-shrink-0">✓</span>
          Book & Earn Points
        </li>
        <li class="flex items-center gap-2">
          <span class="w-5 h-5 rounded-full bg-[rgb(29,53,153)] text-white text-xs flex items-center justify-center flex-shrink-0">✓</span>
          Collect Rewards with Every Stay
        </li>
        <li class="flex items-center gap-2">
          <span class="w-5 h-5 rounded-full bg-[rgb(29,53,153)] text-white text-xs flex items-center justify-center flex-shrink-0">✓</span>
          Redeem Discounts & Exclusive Perks
        </li>
      </ul>
      <a href="{{ path('app_login') }}"
         class="inline-block bg-[rgb(29,53,153)] hover:bg-[rgb(242,182,34)] transition-colors text-white px-6 py-3 rounded-lg shadow">
        Start Earning Rewards
      </a>
    </div>
  </div>
</section>

{# ─── 6. CTA SECTION ──────────────────────────────────────────────────────── #}
<section id="cta" class="py-20 bg-[rgb(29,53,153)] text-white">
  <div class="container mx-auto px-6 text-center">
    <p class="helvetica-condensed text-[rgb(242,182,34)] uppercase tracking-widest text-sm mb-3">Don't Wait</p>
    <h2 style="font-family:'Cinzel', serif;" class="text-3xl md:text-4xl font-thin mb-4">
      Ready to Experience Hotel Diongco?
    </h2>
    <p class="helvetica-condensed text-lg mb-8 max-w-xl mx-auto opacity-90">
      Book your stay today and enjoy luxury rooms, world-class amenities, and exclusive rewards.
    </p>
    <a href="{{ path('app_login') }}"
       class="helvetica-condensed inline-block px-6 py-3 bg-[rgb(242,182,34)] text-white rounded-lg font-semibold hover:bg-yellow-400 transition-colors text-lg">
      Book Now
    </a>
  </div>
</section>

<script src="{{ asset('script/script.js') }}"></script>

{% endblock %}
