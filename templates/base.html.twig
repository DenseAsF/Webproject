<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>{% block title %}Hotel Diongco{% endblock %}</title>
  {% block stylesheets %}
      {{ encore_entry_link_tags('app') }}
    {% endblock %}

  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@100;400;700&display=swap" rel="stylesheet">
<link rel="icon" type="image/png" href="{{ asset('images/logo.svg') }}">
</head>
<body class="bg-gray-50 text-gray-800 antialiased">

  
  <header class="bg-white sticky top-0 z-50 shadow-md">
    {% for type, messages in app.session.flashbag.all() %}
        {% for message in messages %}
            <div class="mx-6 mt-4 p-4 rounded-md helvetica-condensed
                {% if type == 'success' %}bg-green-100 border border-green-400 text-green-700
                {% elseif type == 'error' %}bg-red-100 border border-red-400 text-red-700
                {% else %}bg-blue-100 border border-blue-400 text-blue-700{% endif %}">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}
    {% do app.session.flashbag.clear() %}
    <div class="container mx-auto px-6 py-4 flex items-center justify-between relative">
      <a href="{{ path('homepage') }}" class="flex items-center gap-3">
        <img src="{{ asset('images/logo.svg') }}" alt="Hotel Diongco Logo" class="w-12 h-12 object-contain mb-2">
        <div>
          <div style="font-family: 'Cinzel', serif;" class="text-xl font-thin">Hotel Diongco</div>
        </div>
      </a>

      <div class="flex items-center gap-6 helvetica-condensed">
      <nav class="space-x-4 hidden md:block">
  <a href="{{ path('homepage') }}" 
     class="hover:text-[rgb(242,182,34)] {% if app.request.attributes.get('_route') == 'homepage' %}text-[rgb(242,182,34)] font-semibold{% endif %}">
     Home
  </a>
  <a href="{{ path('about') }}" 
     class="hover:text-[rgb(242,182,34)] {% if app.request.attributes.get('_route') == 'about' %}text-[rgb(242,182,34)] font-semibold{% endif %}">
     About
  </a>
  
  

  <a href="{{ path('app_contact') }}" 
     class="hover:text-[rgb(242,182,34)] {% if app.request.attributes.get('_route') == 'app_contact' %}text-[rgb(242,182,34)] font-semibold{% endif %}">
     Contact</a>

   <a href="{{ path('app_login') }}" 
     class="font-bold hover:text-[rgb(242,182,34)] {% if app.request.attributes.get('_route') == 'app_login' %}text-[rgb(242,182,34)] font-semibold{% endif %}">
     Log In</a>


 <a>
     or</a>
     
  <a href="{{ path('app_register') }}" 
     class="font-bold hover:text-[rgb(242,182,34)] {% if app.request.attributes.get('_route') == 'app_register' %}text-[rgb(242,182,34)] font-semibold{% endif %}">
     Sign Up</a>
</nav>

        <a href="{{ path('homepage') }}" class="bg-[rgb(29,53,153)] hover:bg-[rgb(242,182,34)] transition-colors text-white px-4 py-2 rounded-lg">Book Now</a>
      </div>
    </div>
  </header>


  <main>
    {% block body %}{% endblock %}
  </main>

  <footer class="bg-white mt-16">
    <div class="container mx-auto px-6 py-10 grid md:grid-cols-3 gap-6">
      <div>
        <h3 class="helvetica-condensed">{{ business.name }}</h3>
        <p class="helvetica-57 text-sm text-[rgb(106,117,147)]">{{ business.tagline }}</p>
        <p class="mt-3 text-sm helvetica-condensed">
          {{ business.address }}<br>
          {{ business.email }} {{ business.phone }}
        </p>
      </div>
      <div class="ml-20 helvetica-condensed">
        <h4 class="font-semibold">Services</h4>
        <ul class="helvetica-condensed text-sm text-[rgb(106,117,147)] mt-2 space-y-1">
          <li>Luxury Accommodations</li>
          <li>Dining & Cuisine</li>
          <li>Wellness & Leisure</li>
        </ul>
      </div>
      <div>
        <h4 class="helvetica-condensed">Follow us</h4>
        <p class="helvetica-condensed text-sm text-[rgb(106,117,147)] mt-2">{{ business.social }}</p>
      </div>
    </div>
    <div class="text-center py-4 text-xs text-gray-500">© {{ "now"|date("Y") }} Hotel Diongco</div>
  </footer>

  {% block javascripts %}
    <script src="{{ asset('script/script.js') }}"></script>
  {% endblock %}
</body>
</html>