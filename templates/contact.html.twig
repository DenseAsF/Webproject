{% extends 'base.html.twig' %}

{% block title %}Contact Us - Hotel Diongco{% endblock %}

{% block body %}

{# HERO (About page animation style) #}
<section class="relative h-[650px] overflow-hidden">
  <div class="absolute inset-0 w-full h-full">
    <div class="absolute inset-0 bg-cover bg-center"
         style="background-image: linear-gradient(rgba(0, 20, 77, 0.6), rgba(0,1,34,0.6)), url('{{ asset('images/hotelpatterned.png') }}');">
    </div>
  </div>

  <div class="relative z-10 flex flex-col items-center justify-center h-full text-center px-6">
    <h1 id="contact-hero-title" 
        style="font-family:'Cinzel', serif;" 
        class="text-6xl font-thin text-white mb-4 opacity-0 transition-opacity duration-1000">
      CONTACT US
    </h1>
    
    <p id="contact-hero-subtitle"
       class="helvetica-57 text-2xl text-white mt-4 max-w-2xl opacity-0 transition-opacity duration-1000">
      Reach out to us for reservations, inquiries, or special requests.
    </p>
  </div>
</section>

{# CONTACT SECTION #}
<section class="mt-20 container mx-auto px-6 flex flex-col md:flex-row items-start gap-12 mb-40">

  {# LEFT SIDE #}
  <div class="md:w-1/2">
    <h1 style="font-family:'Cinzel', serif;" class="font-thin text-4xl">
      Get in Touch With Us
    </h1>

    <p class="helvetica-condensed text-[rgb(67,85,145)] mt-5">
      Whether you're planning a stay, booking an event, or just have questions, 
      our team is ready to assist you anytime.
    </p>

    <div class="mt-8 space-y-4 text-[rgb(67,85,145)] helvetica-condensed">
      <p>
        <strong class="text-[rgb(29,53,153)]">Address:</strong><br>
        Rizal Avenue, Dumaguete City, Negros Oriental, Philippines
      </p>

      <p>
        <strong class="text-[rgb(29,53,153)]">Phone:</strong><br>
        +63 969 6969 696
      </p>

      <p>
        <strong class="text-[rgb(29,53,153)]">Email:</strong><br>
        reservations@hoteldiongco.ph
      </p>
    </div>
  </div>

  <div class="md:w-1/2 bg-white rounded-xl shadow-lg p-8">

    
    {% for type, messages in app.session.flashbag.all() %}
      {% for message in messages %}
        <div class="mb-4 p-4 rounded-lg {% if type == 'success' %}bg-green-100 border border-green-400 text-green-700{% elseif type == 'error' %}bg-red-100 border border-red-400 text-red-700{% endif %}">
          {{ message }}
        </div>
      {% endfor %}
    {% endfor %}

    <form action="{{ path('contact_submit') }}" method="POST" class="space-y-6" id="contactForm">

      <div>
        <label class="block text-sm font-semibold text-[rgb(29,53,153)] mb-2">
          Full Name *
        </label>
        <input type="text" name="name" required id="name"
               class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[rgb(242,182,34)]"
               minlength="2" maxlength="100">
        <span class="text-red-500 text-sm hidden" id="nameError">Please enter a valid name (2-100 characters)</span>
      </div>

      <div>
        <label class="block text-sm font-semibold text-[rgb(29,53,153)] mb-2">
          Email *
        </label>
        <input type="email" name="email" required id="email"
               class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[rgb(242,182,34)]">
        <span class="text-red-500 text-sm hidden" id="emailError">Please enter a valid email address</span>
      </div>

      <div>
        <label class="block text-sm font-semibold text-[rgb(29,53,153)] mb-2">
          Phone
        </label>
        <input type="tel" name="phone" id="phone"
               class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[rgb(242,182,34)]"
               placeholder="+63 XXX XXX XXXX" pattern="[\+]?[0-9\s\-\(\)]+">
        <span class="text-red-500 text-sm hidden" id="phoneError">Please enter a valid phone number</span>
      </div>

      <div>
        <label class="block text-sm font-semibold text-[rgb(29,53,153)] mb-2">
          Inquiry Type
        </label>
        <select name="subject"
                class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[rgb(242,182,34)]">
          <option value="Room Reservation">Room Reservation</option>
          <option value="Event Hosting">Event Hosting</option>
          <option value="Dining Inquiry">Dining Inquiry</option>
          <option value="Feedback">Feedback</option>
          <option value="Other">Other</option>
        </select>
      </div>

      <div>
        <label class="block text-sm font-semibold text-[rgb(29,53,153)] mb-2">
          Message *
        </label>
        <textarea name="message" rows="4" required id="message"
                  class="w-full px-4 py-3 border rounded-lg focus:outline-none focus:ring-2 focus:ring-[rgb(242,182,34)]"
                  minlength="10" maxlength="1000"></textarea>
        <span class="text-red-500 text-sm hidden" id="messageError">Please enter a message (10-1000 characters)</span>
      </div>

      <button type="submit" id="submitBtn"
              class="w-full bg-[rgb(29,53,153)] hover:bg-[rgb(242,182,34)] 
                     transition-colors text-white py-3 rounded-lg">
        Send Message
      </button>

    </form>
  </div>
</section>


<script>
document.addEventListener('DOMContentLoaded', () => {

  const title = document.getElementById('contact-hero-title');
  const subtitle = document.getElementById('contact-hero-subtitle');

  setTimeout(() => title.classList.remove('opacity-0'), 500);
  setTimeout(() => subtitle.classList.remove('opacity-0'), 1000);


  const form = document.getElementById('contactForm');
  const nameInput = document.getElementById('name');
  const emailInput = document.getElementById('email');
  const phoneInput = document.getElementById('phone');
  const messageInput = document.getElementById('message');
  const submitBtn = document.getElementById('submitBtn');


  const nameError = document.getElementById('nameError');
  const emailError = document.getElementById('emailError');
  const phoneError = document.getElementById('phoneError');
  const messageError = document.getElementById('messageError');


  function validateName() {
    const name = nameInput.value.trim();
    if (name.length < 2 || name.length > 100) {
      nameError.classList.remove('hidden');
      nameInput.classList.add('border-red-500');
      return false;
    }
    nameError.classList.add('hidden');
    nameInput.classList.remove('border-red-500');
    return true;
  }

  function validateEmail() {
    const email = emailInput.value.trim();
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    if (!emailRegex.test(email)) {
      emailError.classList.remove('hidden');
      emailInput.classList.add('border-red-500');
      return false;
    }
    emailError.classList.add('hidden');
    emailInput.classList.remove('border-red-500');
    return true;
  }

  function validatePhone() {
    const phone = phoneInput.value.trim();
    if (phone && !/^[\+]?[0-9\s\-\(\)]+$/.test(phone)) {
      phoneError.classList.remove('hidden');
      phoneInput.classList.add('border-red-500');
      return false;
    }
    phoneError.classList.add('hidden');
    phoneInput.classList.remove('border-red-500');
    return true;
  }

  function validateMessage() {
    const message = messageInput.value.trim();
    if (message.length < 10 || message.length > 1000) {
      messageError.classList.remove('hidden');
      messageInput.classList.add('border-red-500');
      return false;
    }
    messageError.classList.add('hidden');
    messageInput.classList.remove('border-red-500');
    return true;
  }


  nameInput.addEventListener('blur', validateName);
  emailInput.addEventListener('blur', validateEmail);
  phoneInput.addEventListener('blur', validatePhone);
  messageInput.addEventListener('blur', validateMessage);


  form.addEventListener('submit', (e) => {
    e.preventDefault();
    

    const isNameValid = validateName();
    const isEmailValid = validateEmail();
    const isPhoneValid = validatePhone();
    const isMessageValid = validateMessage();

    if (isNameValid && isEmailValid && isPhoneValid && isMessageValid) {
    
      submitBtn.disabled = true;
      submitBtn.textContent = 'Sending...';
      

      form.submit();
    } else {

      const firstError = document.querySelector('.border-red-500');
      if (firstError) {
        firstError.focus();
        firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    }
  });
});
</script>

{% endblock %}