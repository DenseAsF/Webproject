{% extends 'base.html.twig' %}

{% block title %}Log in{% endblock %}

{% block body %}

<div class="relative min-h-screen flex justify-center items-center">
  
    <div class="absolute inset-0">
    <div class="w-full h-full bg-cover bg-center" style="background-image: linear-gradient(rgba(0, 20, 77, 0.6), rgba(0,1,34,0.6)), url('{{ asset('images/hotelpatterned.png') }}')"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-[rgba(0,32,91,0.7)] to-[rgba(0,32,91,0.7)]"></div>
</div>

    <div class="relative w-full max-w-xl bg-white rounded-xl shadow-lg p-6 z-10">
        <h2 class="text-xl font-bold mb-5 text-center">Sign In</h2>

        {% if error %}
            <div class="bg-red-100 border border-red-400 text-red-700 p-3 mb-4 rounded">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {% if app.user %}
            <div class="mb-3 text-center text-sm">
                You are logged in as <b>{{ app.user.userIdentifier }}</b><br>
                <a href="{{ path('app_logout') }}" class="text-red-600 hover:underline">Logout</a>
            </div>
        {% endif %}

        <form method="post" action="{{ path('app_login') }}">
            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            
            <div class="mb-3">
                <label class="block text-gray-600 text-sm mb-1">Username</label>
                <input
                    type="text"
                    name="_username"
                    value="{{ last_username }}"
                    required
                    autofocus
                    class="w-full border rounded px-3 py-2 text-sm"
                >
            </div>

            <div class="mb-3">
                <label class="block text-gray-600 text-sm mb-1">Password</label>
                <input
                    type="password"
                    name="_password"
                    required
                    class="w-full border rounded px-3 py-2 text-sm"
                >
            </div>

            <div class="mb-4 flex items-center text-sm">
                <input type="checkbox" name="_remember_me" class="mr-2">
                Remember me
            </div>

            <button
                type="submit"
                class="w-full bg-blue-600 hover:bg-blue-700 text-white py-2 rounded text-sm font-medium"
            >
                Log In
            </button>
        </form>

        <div class="text-center mt-6">
            <p class="mb-4">— or —</p>
            <a href="{{ path('app_google_connect') }}"
               class="inline-flex items-center gap-2 bg-white border border-gray-300 rounded px-4 py-2 font-bold text-gray-800 hover:bg-gray-100">
                <img src="https://developers.google.com/identity/images/g-logo.png" width="20" height="20" alt="Google">
                Sign in with Google
            </a>
        </div>

        <div class="mt-4 text-center text-sm">
            <p>Don't have an account? <a href="{{ path('app_register') }}" class="text-blue-600 hover:underline">Register here</a></p>
        </div>
    </div>
</div>

{% endblock %}