{% extends 'base.html.twig' %}

{% block title %}Register{% endblock %}

{% block body %}

<div class="relative min-h-screen flex justify-center items-center">
    
    <div class="absolute inset-0">
        <div class="w-full h-full bg-cover bg-center" style="background-image: linear-gradient(rgba(0, 20, 77, 0.6), rgba(0,1,34,0.6)), url('{{ asset('images/hotelpatterned.png') }}')"></div>
    </div>

    <div class="relative w-full max-w-xl bg-white rounded-xl shadow-lg p-6 z-10">
        <h2 class="text-xl font-bold mb-5 text-center">Create Account</h2>

        {{ form_start(registrationForm, {
            'attr': {
                'data-turbo': 'false',
                'novalidate': 'novalidate',
                'onsubmit': 'return validateForm(event)'
            }
        }) }}
        
        <div class="mb-3">
            {{ form_label(registrationForm.username, 'Username', {'label_attr': {'class': 'block text-gray-600 text-sm mb-1'}}) }}
            {{ form_widget(registrationForm.username, {'attr': {
                'class': 'w-full border-2 border-blue-300 rounded px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200',
                'required': 'required',
                'autofocus': 'autofocus',
                'id': 'username',
                'oninput': 'clearUsernameError()'
            }}) }}
            <div id="username-error" class="text-red-600 text-sm mt-1 font-medium hidden"></div>
            {% if registrationForm.username.vars.errors|length > 0 %}
                <div class="text-red-600 text-sm mt-1 font-medium">
                    {% for error in registrationForm.username.vars.errors %}
                        {{ error.message }}
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="mb-3">
            {{ form_label(registrationForm.name, 'Full Name', {'label_attr': {'class': 'block text-gray-600 text-sm mb-1'}}) }}
            {{ form_widget(registrationForm.name, {'attr': {
                'class': 'w-full border-2 border-blue-300 rounded px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200',
                'required': 'required'
            }}) }}
            {% if registrationForm.name.vars.errors|length > 0 %}
                <div class="text-red-600 text-sm mt-1 font-medium">
                    {% for error in registrationForm.name.vars.errors %}
                        {{ error.message }}
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="mb-3">
            {{ form_label(registrationForm.email, 'Email', {'label_attr': {'class': 'block text-gray-600 text-sm mb-1'}}) }}
            {{ form_widget(registrationForm.email, {'attr': {
                'class': 'w-full border-2 border-blue-300 rounded px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200',
                'required': 'required'
            }}) }}
            {% if registrationForm.email.vars.errors|length > 0 %}
                <div class="text-red-600 text-sm mt-1 font-medium">
                    {% for error in registrationForm.email.vars.errors %}
                        {{ error.message }}
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="mb-3">
            {{ form_label(registrationForm.phone, 'Phone Number', {'label_attr': {'class': 'block text-gray-600 text-sm mb-1'}}) }}
            {{ form_widget(registrationForm.phone, {'attr': {
                'class': 'w-full border-2 border-blue-300 rounded px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200',
                'required': 'required'
            }}) }}
            {% if registrationForm.phone.vars.errors|length > 0 %}
                <div class="text-red-600 text-sm mt-1 font-medium">
                    {% for error in registrationForm.phone.vars.errors %}
                        {{ error.message }}
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="mb-3">
            {{ form_label(registrationForm.age, 'Age', {'label_attr': {'class': 'block text-gray-600 text-sm mb-1'}}) }}
            {{ form_widget(registrationForm.age, {'attr': {
                'class': 'w-full border-2 border-blue-300 rounded px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200',
                'required': 'required'
            }}) }}
            {% if registrationForm.age.vars.errors|length > 0 %}
                <div class="text-red-600 text-sm mt-1 font-medium">
                    {% for error in registrationForm.age.vars.errors %}
                        {{ error.message }}
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <div class="mb-3">
            {{ form_label(registrationForm.plainPassword, 'Password', {'label_attr': {'class': 'block text-gray-600 text-sm mb-1'}}) }}
            {{ form_widget(registrationForm.plainPassword, {'attr': {
                'class': 'w-full border-2 border-blue-300 rounded px-3 py-2 text-sm focus:border-blue-500 focus:outline-none focus:ring-2 focus:ring-blue-200',
                'required': 'required'
            }}) }}
            {% if registrationForm.plainPassword.vars.errors|length > 0 %}
                <div class="text-red-600 text-sm mt-1 font-medium">
                    {% for error in registrationForm.plainPassword.vars.errors %}
                        {{ error.message }}
                    {% endfor %}
                </div>
            {% endif %}
        </div>

        <button
            type="submit"
            class="w-full bg-blue-600 hover:bg-blue-700 text-white py-2 rounded text-sm font-medium"
        >
            Register
        </button>
        
        {{ form_end(registrationForm) }}
        
        <div class="mt-4 text-center text-sm">
            <p>Already have an account? <a href="{{ path('app_login') }}" class="text-blue-600 hover:underline">Sign In</a></p>
        </div>
    </div>
</div>

<script>
function validateForm(event) {
    const usernameInput = document.getElementById('username');
    const usernameError = document.getElementById('username-error');
    const usernameValue = usernameInput.value.trim();
    
    // Check if username is empty
    if (usernameValue === '') {
        event.preventDefault(); // Prevent form submission
        usernameError.textContent = 'Username cannot be empty. Please enter a username.';
        usernameError.classList.remove('hidden');
        usernameInput.classList.add('border-red-500', 'focus:border-red-500');
        usernameInput.focus();
        return false;
    }
    
    // Additional validation: check for minimum length (optional)
    if (usernameValue.length < 3) {
        event.preventDefault();
        usernameError.textContent = 'Username must be at least 3 characters long.';
        usernameError.classList.remove('hidden');
        usernameInput.classList.add('border-red-500', 'focus:border-red-500');
        usernameInput.focus();
        return false;
    }
    
    // Clear any existing errors
    clearUsernameError();
    return true;
}

function clearUsernameError() {
    const usernameInput = document.getElementById('username');
    const usernameError = document.getElementById('username-error');
    
    if (usernameError) {
        usernameError.textContent = '';
        usernameError.classList.add('hidden');
    }
    
    if (usernameInput) {
        usernameInput.classList.remove('border-red-500', 'focus:border-red-500');
        usernameInput.classList.add('border-blue-300');
    }
}

// Optional: Add real-time validation as user types
document.addEventListener('DOMContentLoaded', function() {
    const usernameInput = document.getElementById('username');
    if (usernameInput) {
        usernameInput.addEventListener('input', function() {
            if (this.value.trim() !== '') {
                clearUsernameError();
            }
        });
    }
});
</script>

<style>
.border-red-500 {
    border-color: #ef4444 !important;
}

.focus\:border-red-500:focus {
    border-color: #ef4444 !important;
}
</style>

{% endblock %}